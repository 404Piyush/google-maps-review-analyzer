{
  "name": "google-maps-review-analyzer",
  "version": "1.6.0",
  "description": "Stealth-scrape Google Maps reviews via Puppeteer + proxy rotation OR pull via Places API, then generate an executive-grade sentiment report using local Ollama LLMs or OpenRouter free models. Includes a Dockerized scraper HTTP backend deployable to Render.",
  "main": "index.js",
  "bin": {
    "reatlas": "./bin/cli.js",
    "gmaps-analyzer": "./bin/cli.js"
  },
  "scripts": {
    "reatlas": "node bin/cli.js",
    "scrape": "node bin/cli.js scrape",
    "scrape:api": "node bin/cli.js scrape --api",
    "scrape:fast": "node bin/cli.js scrape --fast",
    "analyze": "node bin/cli.js analyze",
    "analyze:llm": "node bin/cli.js analyze --model=balanced",
    "analyze:fast": "node bin/cli.js analyze --model=fast",
    "analyze:openrouter": "node bin/cli.js analyze --model=fast --provider=openrouter",
    "analyze:basic": "node bin/cli.js analyze --model=fast",
    "demo": "node dev-server.js",
    "dev:web": "node dev-server.js",
    "dev": "node --watch index.js",
    "dev:scraper": "node --watch scraper-server.js",
    "start:scraper": "node scraper-server.js",
    "test": "node --test test/*.test.js",
    "lint": "for f in index.js topic-analysis.js places-api.js analyze.js bin/cli.js bin/commands/*.js lib/*.js test/*.js api/*.js dev-server.js scraper-server.js; do [ -f \"$f\" ] && node --check \"$f\"; done",
    "test:captcha": "node test-captcha.js"
  },
  "keywords": [
    "puppeteer",
    "puppeteer-extra",
    "stealth",
    "web-scraping",
    "google-maps",
    "reviews",
    "sentiment-analysis",
    "ollama",
    "llm",
    "automation",
    "openrouter",
    "places-api",
    "cli",
    "scraper",
    "review-analyzer"
  ],
  "author": {
    "name": "Piyush Utkar",
    "email": "piyushutkar123@gmail.com",
    "url": "https://404piyush.me"
  },
  "homepage": "https://github.com/404Piyush/google-maps-review-analyzer#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/404Piyush/google-maps-review-analyzer.git"
  },
  "bugs": {
    "url": "https://github.com/404Piyush/google-maps-review-analyzer/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "axios": "^1.10.0",
    "d3": "^7.9.0",
    "d3-cloud": "^1.2.9",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "marked": "^18.0.6",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.4"
  },
  "optionalDependencies": {
    "puppeteer": "^21.6.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  }
}
