# ===== Target =====
# The Google Maps URL to scrape (must be a maps.app.goo.gl or full /maps/place/ URL)
GOOGLE_MAPS_URL=https://maps.app.goo.gl/CCGmfPudoLzPoK2a7

# ===== Scraping (index.js) =====
PARALLEL_PROXIES=2
NAV_TIMEOUT_MS=30000
NAV_SETTLE_MS=1500
CLICK_DELAY_MS=1500
SCROLL_INTERVAL_MS=1800
MAX_STABLE_CHECKS=3
CACHE_TTL_HOURS=24

# ===== LLM (topic-analysis.js) =====
# Provider: 'ollama' (local) or 'openrouter' (free hosted models)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
# Tier: 'fast' (gemma2:2b only), 'balanced' (gemma2:2b + qwen3:8b), 'deep' (qwen3:8b for both)
MODEL_TIER=fast
# Reviews per Ollama inference (higher = fewer roundtrips, more VRAM)
BATCH_SIZE=10
# 0 = auto-detect from hardware
CONCURRENCY_LIMIT=0

# OpenRouter (only used when LLM_PROVIDER=openrouter)
# Get a free key at https://openrouter.ai/
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# ===== Places API (places-api.js) =====
GOOGLE_PLACES_API_KEY=
PLACE_TEXT_QUERY=
