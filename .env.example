# Ollama configuration (optional)
# Override the defaults baked into topic-analysis.js by exporting these before
# running, e.g.:
#   OLLAMA_API_URL=http://192.168.1.50:11434/api/generate node topic-analysis.js

OLLAMA_API_URL=http://localhost:11434/api/generate
FAST_MODEL=gemma2:2b
POWERFUL_MODEL=qwen3:8b
CONCURRENCY_LIMIT=50

# Google Maps URL to scrape (defaults to the hard-coded one in index.js)
GOOGLE_MAPS_URL=https://maps.app.goo.gl/CCGmfPudoLzPoK2a7
