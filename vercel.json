{
  "version": 2,
  "builds": [
    {
      "src": "demo/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/", "dest": "/demo/index.html" },
    { "src": "/(.*)", "dest": "/demo/$1" }
  ]
}
